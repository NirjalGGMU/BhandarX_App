{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (Root Workspace)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/bhandarx_flutter",
      "program": "lib/main.dart"
    },
    {
      "name": "Flutter (Root Workspace, Profile)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/bhandarx_flutter",
      "program": "lib/main.dart",
      "flutterMode": "profile"
    },
    {
      "name": "Flutter (Root Workspace, Release)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/bhandarx_flutter",
      "program": "lib/main.dart",
      "flutterMode": "release"
    }
  ]
}
