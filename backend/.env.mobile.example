# Copy this to .env.mobile and customize values
NODE_ENV=development
PORT=5002
API_VERSION=v1
MONGODB_URI=mongodb://localhost:27017/bhandarx_inventory_mobile
MONGODB_TEST_URI=mongodb://localhost:27017/bhandarx_inventory_mobile_test
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key
JWT_REFRESH_EXPIRE=30d
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
LOG_LEVEL=debug
LOG_FILE=logs/mobile.log
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
MAX_FILE_SIZE=5242880
UPLOAD_PATH=uploads/
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=BhandarX <noreply@bhandarx.com>
FRONTEND_URL=http://localhost:3000
